rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Zero-Trust Concept: Deny all by default unless explicitly allowed.
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profile Rules
    match /users/{userId} {
      // Users can only read and update their own profiles
      allow read, update: if request.auth != null && request.auth.uid == userId;
      
      // Profiles can ONLY be created by the backend (Cloud Function trigger or FastAPI admin)
      allow create: if false; 
      
      // No deletion from client apps
      allow delete: if false;

      // User Sessions (Managed strictly by FastAPI backend)
      match /sessions/{sessionId} {
        // Users can view their own sessions
        allow read: if request.auth != null && request.auth.uid == userId;
        // The backend handles writing session records (Admin SDK bypasses these rules)
        allow write: if false; 
      }

      // Phishing Analytics (Managed strictly by AI pipeline in backend)
      match /analyses/{analysisId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; 
      }
    }
  }
}
