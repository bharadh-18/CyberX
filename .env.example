# API Config
PROJECT_NAME="Zero-Trust Backend API"
VERSION="1.0.0"
DEBUG=True
LOG_LEVEL=DEBUG

# Secrets (Rotate these in Production!)
SECRET_KEY="replace_with_a_secure_random_string_in_production"
ENCRYPTION_MASTER_KEY="32_byte_base64_encryption_key_goes_here"

# Database
# For Local: sqlite+aiosqlite:///./test.db
# For Docker: postgresql+asyncpg://user:pass@postgres:5432/ztapi
DATABASE_URL="sqlite+aiosqlite:///./test.db"

# Redis (for Rate Limiting)
REDIS_URL="redis://localhost:6379/0"

# JWT Config
JWT_ALGORITHM="HS256"
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Google OAuth Config
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:8443/auth/google/callback"

# Feature Flags
ENABLE_MFA=True
ENABLE_ELK=False
ELASTICSEARCH_URL="http://localhost:9200"
SPLUNK_HEC_URL=""
SPLUNK_HEC_TOKEN=""
